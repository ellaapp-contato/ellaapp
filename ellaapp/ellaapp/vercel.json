{
  "functions": {
    "api/chat.js": {
      "maxDuration": 30
    },
    "api/checkout.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/app", "destination": "/index.html" },
    { "source": "/app/(.*)", "destination": "/$1" }
  ],
  "redirects": [
    { "source": "/", "destination": "/landing/", "permanent": false }
  ]
}
