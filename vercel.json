{
  "version": 2,
  "builds": [
    {
      "src": "ellaapp/ellaapp/api/chat.js",
      "use": "@vercel/node"
    },
    {
      "src": "ellaapp/ellaapp/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/chat",
      "dest": "ellaapp/ellaapp/api/chat.js"
    },
    {
      "src": "/(.*)",
      "dest": "ellaapp/ellaapp/$1"
    }
  ]
}
